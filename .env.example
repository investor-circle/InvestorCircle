# ── Firebase (authentication) ──────────────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → Your apps → Web app config
# See src/firebase.js for setup instructions.
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# ── Finnhub (live stock prices) ────────────────────────────────────────────────
# Sign up free at https://finnhub.io — no credit card, key shown on dashboard.
VITE_FINNHUB_KEY=your_finnhub_api_key_here

# ── Neon (database persistence) ───────────────────────────────────────────────
# Find in Neon dashboard: Project → Connection Details → Connection string.
VITE_DATABASE_URL=postgresql://user:password@ep-xxx.ap-south-1.aws.neon.tech/neondb?sslmode=require
