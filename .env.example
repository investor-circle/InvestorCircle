# Copy this file to `.env` and fill in your Neon connection string.
# Find it in your Neon dashboard: Project → Connection Details → Connection string.
# These are only needed when you wire up persistence; the app runs on mock data without them.
#
# ⚠️  Keep .env out of git — it's already in .gitignore.
# ⚠️  For production: move DB queries to an API route so this string never
#     reaches the browser bundle. Fine to expose for a personal prototype.
VITE_DATABASE_URL=postgresql://user:password@ep-xxx-xxxxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
